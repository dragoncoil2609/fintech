# Base URL of the FastAPI backend.
# Leave blank to use the Vite dev proxy (requests go to /api → http://localhost:8000).
# In production, set to the deployed backend, e.g. https://api.budgetbot.example.com
VITE_API_URL=http://localhost:8000

# When true, the app starts with built-in mock data so the UI looks alive
# without a running backend. Set to false to talk to the real API from first load.
VITE_USE_MOCK=true

# AWS Cognito (login / register / logout). Leave these blank to run guest-only:
# the auth screen then offers just "Continue as guest" and skips real sign-up.
# Values come from `terraform output` (cognito_user_pool_id / cognito_client_id / cognito_region).
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=ap-southeast-1
