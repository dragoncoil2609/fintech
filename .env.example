# =============================================================================
# BudgetBot — environment configuration
# =============================================================================
# Local defaults work without AWS. Switch backends to bedrock / s3 / dynamodb to deploy.

# ----- AI backend -----
# Options: bedrock | local
# - bedrock: real Bedrock InvokeModel — categorizes each transaction via LLM
# - local:   rule-based fallback (keyword matching), no AWS call
AI_BACKEND=local
AI_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_REGION=ap-southeast-1

# ----- Object storage (raw uploaded statements) -----
# Options: s3 | local. Prod uses s3 so the API (writer) and the async worker
# (reader) share durable upload objects.
STORAGE_BACKEND=local
STORAGE_BUCKET=
STORAGE_LOCAL_DIR=./_data/uploads

# ----- Async upload pipeline (POST /enqueue → SQS → worker → /job-status) -----
# Set on BOTH the API and the worker. Empty → /enqueue processes inline (local dev).
# The worker runs as `python -m src.worker`.
SQS_QUEUE_URL=

# ----- PDF receipt extraction backend -----
# Options: local | bedrock
# - local:   offline stub (no AWS) — returns a deterministic mock receipt
# - bedrock: PDF → PNG (PyMuPDF) → Claude Haiku vision (needs: pip install pymupdf)
PDF_BACKEND=local

# ----- Transaction DB backend -----
# DB_BACKEND takes precedence over USERSTORE_BACKEND when set.
# Options: sqlite | postgres | dynamodb | documentdb | mysql  (default sqlite)
# Note: query patterns include GROUP BY category → SQL (Postgres) is the natural fit,
# but DynamoDB works if you denormalize. SQLite for local dev only.
DB_BACKEND=sqlite
DB_PATH=./budgetbot.db                         # sqlite file path (alias of USERSTORE_SQLITE_PATH)
USERSTORE_BACKEND=sqlite
USERSTORE_TABLE=budgetbot-transactions       # for dynamodb
USERSTORE_POSTGRES_URL=                       # for postgres (or use DB_SECRET_NAME)
USERSTORE_SQLITE_PATH=./_data/transactions.db
# Prod (RDS): set USERSTORE_BACKEND=postgres + DB_SECRET_NAME; the app pulls the
# DSN from Secrets Manager at boot (keys: DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME).
# Terraform provisions the RDS instance + secret and wires these automatically.
DB_SECRET_NAME=                               # e.g. budgetbot/db
DB_SSLMODE=require                            # RDS TLS

# ----- Bedrock cost model (Claude 3.5 Haiku, USD per 1M tokens) -----
BEDROCK_INPUT_COST_PER_1M=0.25
BEDROCK_OUTPUT_COST_PER_1M=1.25
CSV_CLASSIFY_BATCH_SIZE=10
MAX_PDF_SIZE_MB=5

# ----- Deduplication -----
# DEDUP_ENABLED=false disables all dedup logic (handy for local testing).
DEDUP_ENABLED=true
DEDUP_DATE_TOLERANCE_DAYS=1                   # transaction match window (± days)
DEDUP_MANUAL_WARN_DAYS=3                      # manual-entry soft-warning window

# ----- Merchant catalog cache (skip the LLM for repeat merchants) -----
CATALOG_ENABLED=true
CATALOG_MIN_SAMPLES=3                         # times a merchant must be seen before caching
CATALOG_MIN_CONFIDENCE=0.8                    # min avg confidence to trust the cache

# ----- Budget guard (USD; 0 disables a check) — degrade to LocalAI not overspend -----
MAX_COST_PER_REQUEST_USD=0.50
MAX_COST_PER_USER_PER_DAY_USD=1.00
EST_TOKENS_PER_ROW=60                         # per-request cost estimate input

# ----- Bedrock prompt caching (cachePoint on the large static chat prompt) -----
PROMPT_CACHE_ENABLED=true

# ----- Bedrock reliability -----
BEDROCK_MAX_ATTEMPTS=3                        # adaptive retry/backoff on throttling

# ----- Idempotency -----
IDEMPOTENCY_TTL_DAYS=2                        # how long Idempotency-Key replays are cached

# ----- API rate limiting (per-user, fixed window/min) -----
# REDIS_URL empty → in-memory limiter (single task/local). Set it (Redis/Valkey,
# e.g. ElastiCache) to share the limit across Fargate tasks. rediss:// for TLS.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
REDIS_URL=

# ----- PDF receipt extraction fallback -----
# When Bedrock vision fails and this is on, try AWS Textract AnalyzeExpense
# before degrading to a manual-entry preview. Needs textract:AnalyzeExpense IAM.
TEXTRACT_ENABLED=false

# ----- Identity / Auth -----
DEFAULT_USER_ID=test-user-001
# REQUIRE_AUTH=true → every request must carry a valid Cognito `Authorization:
# Bearer <token>`; user_id = JWT `sub` (X-User-Id is ignored). Off by default so
# local/demo (X-User-Id) and tests work. Prod (terraform) sets these from Cognito.
REQUIRE_AUTH=false
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Frontend serving (split deploy?) -----
# When SERVE_FRONTEND=true, the backend serves frontend/index.html at /.
# Set SERVE_FRONTEND=false if you deploy frontend separately to CloudFront+S3,
# Amplify, ALB+S3, or anywhere else. The frontend will then need its API_BASE
# set to point to this backend URL.
SERVE_FRONTEND=true

# ----- CORS -----
# Comma-separated list of allowed origins. Vite dev = 5173, CRA = 3000.
# Use '*' for a quick demo, or pin to your frontend URL in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- Extra DB backends (optional — require requirements-optional.txt) -----
# To use DocumentDB or RDS MySQL, set USERSTORE_BACKEND accordingly AND install
# the extra deps:  pip install -r requirements-optional.txt
#
# Options: dynamodb | postgres | sqlite | documentdb | mysql
USERSTORE_MONGO_URL=                         # for documentdb (DocumentDB or MongoDB Atlas)
USERSTORE_MONGO_DB=budgetbot                   # database name on the MongoDB instance
USERSTORE_MONGO_TLS_CA=                      # path to RDS CA bundle for DocumentDB TLS verify
USERSTORE_MYSQL_URL=                         # for mysql (mysql://user:pw@host:3306/db)
